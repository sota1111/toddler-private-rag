# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
#
# Values with a default in variables.tf can be omitted; they are listed here so
# you can confirm/override them. Values WITHOUT a default are required.

# --- Public literals (defaults exist; override only if they differ) ---
project_id          = "gen-lang-client-0243034020"
region              = "asia-northeast1"
gcs_bucket_name     = "gen-lang-client-0243034020-toddler-private-rag"
gcs_bucket_location = "ASIA-NORTHEAST1"
firestore_location  = "asia-northeast1"
gemini_model        = "gemini-3.5-flash"
gemini_location     = "global"

# Resource names — these are GitHub Actions secrets today. CONFIRM the real
# values against GCP (gcloud run services list /
# gcloud artifacts repositories list) before importing; the defaults are guesses.
artifact_registry_repository = "toddler-private-rag"
backend_service_name         = "toddler-private-rag-backend"
frontend_service_name        = "toddler-private-rag-frontend"
upload_service_name          = "upload-api" # SOT-1376: Cloud Run upload-api (matches secret CLOUD_RUN_SERVICE_UPLOAD)

# --- Required (no default) — supply real values ---

# gcloud projects describe gen-lang-client-0243034020 --format='value(projectNumber)'
project_number = "000000000000"

# owner/name of this repo, used to scope WIF.
github_repository = "sota1111/toddler-private-rag"

# Short IDs of the existing Workload Identity pool/provider (GitHub secret
# GCP_WORKLOAD_IDENTITY_PROVIDER encodes these in its path:
# projects/<num>/locations/global/workloadIdentityPools/<POOL>/providers/<PROVIDER>)
wif_pool_id     = "github-pool"
wif_provider_id = "github-provider"

# Account id (before @) of the deploy SA (GitHub secret GCP_SERVICE_ACCOUNT).
deploy_service_account_id = "github-actions-deployer"

# --- Optional ---
# Dedicated least-privilege runtime service accounts (SOT-1366 item A).
# Leave empty to keep the default compute SA; set to the SA emails once created
# (terraform output runtime_service_account_email / frontend_service_account_email).
cloud_run_service_account_email = "" # e.g. toddler-run-runtime@gen-lang-client-0243034020.iam.gserviceaccount.com
frontend_service_account_email  = "" # e.g. toddler-run-frontend@gen-lang-client-0243034020.iam.gserviceaccount.com

# --- SOT-1366 item B: orphan-attachment cleanup scheduler ---
# Cron (Asia/Tokyo). Default daily 03:00.
orphan_purge_schedule = "0 3 * * *"
# Value of rag-worker-invoke-token; sent as X-Worker-Token. Sensitive — keep in
# the gitignored terraform.tfvars only. Managed out-of-band (like other secrets).
worker_invoke_token = ""

# Container images are built & pushed by CI and ignored by Terraform; normally
# leave these unset.
# backend_image  = ""
# frontend_image = ""
# upload_image   = ""
