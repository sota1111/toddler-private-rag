APP_ENV=local

# ===================================
# Firebase Authentication設定
# ===================================
# Firebase Console > プロジェクト設定 > アプリ から取得
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# 許可するメールアドレス（カンマ区切り）
# Cloud Run本番環境ではSecret Manager管理推奨
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用シークレット（32文字以上推奨）
# Cloud Run本番環境ではSecret Manager管理
AUTH_SECRET=your-random-secret-key-here

# Firebase Admin SDK用（GCP_PROJECT_IDと同じ値）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ===================================
# GCP / Cloud Run デプロイ設定
# ===================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=toddler-private-rag-backend
ARTIFACT_REGISTRY_REPOSITORY=toddler-rag-registry
IMAGE_NAME=toddler-private-rag-backend
