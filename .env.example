APP_ENV=local

# ===================================
# Firebase Authentication設定（案1: サーバサイドREST認証）
# ===================================
# ブラウザはFirebaseと直接通信しません。backendが Identity Toolkit REST
# (accounts:signInWithPassword) でメール/パスワードを照合します。
# Firebase Web API key（Firebase Console > プロジェクト設定 > アプリ）をサーバ側に配線。
# Cloud Run本番環境ではSecret Manager (rag-firebase-api-key) 管理推奨
FIREBASE_API_KEY=your-firebase-web-api-key

# 許可するメールアドレス（カンマ区切り）
# Cloud Run本番環境ではSecret Manager管理推奨
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用シークレット（32文字以上推奨）
# Cloud Run本番環境ではSecret Manager管理
AUTH_SECRET=your-random-secret-key-here

# GCPプロジェクトID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# 許可するフロントエンドOrigin（カンマ区切り）。本番はCloud RunのフロントURL
CORS_ORIGINS=http://localhost:5173

# ===================================
# GCP / Cloud Run デプロイ設定
# ===================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=toddler-private-rag-backend
ARTIFACT_REGISTRY_REPOSITORY=toddler-rag-registry
IMAGE_NAME=toddler-private-rag-backend

# ===================================
# 永続化設定 (SOT-671/672)
# ===================================
# ストレージbackend: local | gcs
STORAGE_BACKEND=local
GCS_BUCKET_NAME=your-gcs-bucket-name

# メタデータbackend: sqlite | firestore
DATABASE_TYPE=sqlite
FIRESTORE_DATABASE=(default)
