APP_ENV=local

# ===================================
# Firebase Authentication設定（案1: サーバサイドREST認証）
# ===================================
# 注: これらの認証用環境変数は backend サーバ側で読み込まれます。
# frontend は Firebase クライアント設定（VITE_FIREBASE_*）を必要としません
# （/api/auth/session 経由のサーバサイド認証のため）。
#
# ブラウザはFirebaseと直接通信しません。backendが Identity Toolkit REST
# (accounts:signInWithPassword) でメール/パスワードを照合します。
# Firebase Web API key（推奨名: FIREBASE_WEB_API_KEY、後方互換で FIREBASE_API_KEY も可）
# backend は FIREBASE_WEB_API_KEY を優先し、無ければ FIREBASE_API_KEY にfallback。
# Cloud Run本番環境ではSecret Manager (rag-firebase-api-key) 管理推奨
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_API_KEY=your-firebase-web-api-key

# 許可するメールアドレス（カンマ区切り）
# Cloud Run本番環境ではSecret Manager管理推奨
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用シークレット（32文字以上推奨）
# Cloud Run本番環境ではSecret Manager管理
AUTH_SECRET=your-random-secret-key-here

# GCPプロジェクトID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# 許可するフロントエンドOrigin（カンマ区切り）。本番はCloud RunのフロントURL
CORS_ORIGINS=http://localhost:5173

# ===================================
# GCP / Cloud Run デプロイ設定
# ===================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=toddler-private-rag-backend
ARTIFACT_REGISTRY_REPOSITORY=toddler-rag-registry
IMAGE_NAME=toddler-private-rag-backend

# ===================================
# 永続化設定 (SOT-671/672)
# ===================================
# ストレージbackend: local | gcs
STORAGE_BACKEND=local
GCS_BUCKET_NAME=your-gcs-bucket-name

# メタデータbackend: sqlite | firestore
DATABASE_TYPE=sqlite
FIRESTORE_DATABASE=(default)

# ===================================
# RAG（ベクトル検索＋LLM回答生成） (SOT-766)
# ===================================
# Provider切替: fake | gemini
# 既定は fake（決定論的・APIキー不要でオフライン動作）。本番でLLM/埋め込みを
# 使う場合のみ gemini を指定し、GEMINI_API_KEY を設定する。
EMBEDDING_PROVIDER=fake
LLM_PROVIDER=fake
# gemini provider 利用時のみ必要（google-generativeai が必要）
# GEMINI_API_KEY=your-gemini-api-key

# ===================================
# データ保持 / プライバシー設定 (SOT-780)
# ===================================
# アップロード添付の保持日数。0 または未設定で無期限（パージ無効）。
# 正の値を設定すると、purge_expired_attachments がこの日数を超えた添付を削除対象にする。
ATTACHMENT_RETENTION_DAYS=0
